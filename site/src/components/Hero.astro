---
import { Image } from 'astro:assets';
import fotografaPrincipal from '../assets/images/fotografa/fotografa_1-sin fondo.png';
import floatNaturaleza from '../assets/images/fotografias/naturaleza/naturaleza_1.jpg';
import floatRetrato from '../assets/images/fotografias/retratos/retrato_1.jpg';
---

<section class="hero" aria-labelledby="hero-heading">
  <div class="hero__bg-pattern" aria-hidden="true"></div>

  <div class="container hero__inner">
    <div class="hero__content">
      <p class="section-label hero__label">Fotógrafa Documental · Colombia</p>

      <h1 class="hero__title" id="hero-heading">
        La luz que<br />
        <span class="hero__title-accent">cuenta historias</span><br />
        reales
      </h1>

      <p class="hero__desc">
        Capturando la intersección entre territorio, biodiversidad y comunidades humanas.
        Más de una década documentando la Colombia profunda con honestidad y respeto.
      </p>

      <div class="hero__stats" aria-label="Estadísticas profesionales">
        <div class="hero__stat">
          <span class="hero__stat-num">10+</span>
          <span class="hero__stat-label">Años de experiencia</span>
        </div>
        <div class="hero__stat-divider" aria-hidden="true"></div>
        <div class="hero__stat">
          <span class="hero__stat-num">28</span>
          <span class="hero__stat-label">Departamentos recorridos</span>
        </div>
        <div class="hero__stat-divider" aria-hidden="true"></div>
        <div class="hero__stat">
          <span class="hero__stat-num">5</span>
          <span class="hero__stat-label">Premios internacionales</span>
        </div>
      </div>

      <div class="hero__actions">
        <a href="#portafolio" class="btn-primary">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="2"/>
            <circle cx="8.5" cy="8.5" r="1.5"/>
            <polyline points="21 15 16 10 5 21"/>
          </svg>
          Ver portafolio
        </a>
        <a href="#contacto" class="btn-outline">Contactar</a>
      </div>

      <div class="hero__awards" aria-label="Reconocimientos destacados">
        <span class="hero__award-badge">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/>
          </svg>
          Premio Simón Bolívar 2017
        </span>
        <span class="hero__award-badge">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/>
          </svg>
          Finalista World Press Photo 2022
        </span>
        <span class="hero__award-badge">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/>
          </svg>
          National Geographic · The Guardian
        </span>
      </div>
    </div>

    <div class="hero__visual" aria-hidden="true">
      <div class="hero__img-wrapper">
        <Image
          src={fotografaPrincipal}
          alt="Valentina Ríos Mendoza, fotógrafa documental"
          width={480}
          format="webp"
          quality={85}
          fetchpriority="high"
          class="hero__img"
        />
        <div class="hero__img-card hero__img-card--top">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/>
            <circle cx="12" cy="13" r="4"/>
          </svg>
          <div>
            <span class="card-title">Canon EOS R5</span>
            <span class="card-sub">45MP · 8K RAW</span>
          </div>
        </div>
        <div class="hero__img-card hero__img-card--bottom">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
          </svg>
          <div>
            <span class="card-title">Lente Verde 2021</span>
            <span class="card-sub">Latinoamérica</span>
          </div>
        </div>
      </div>

      <div class="hero__floating-imgs">
        <Image src={floatNaturaleza} alt="" width={120} format="avif" quality={70} loading="lazy" class="hero__float hero__float--1 blur-img" />
        <Image src={floatRetrato} alt="" width={100} format="avif" quality={70} loading="lazy" class="hero__float hero__float--2 blur-img" />
      </div>
    </div>
  </div>

  <div class="hero__scroll" aria-label="Desplazarse hacia abajo">
    <div class="hero__scroll-line"></div>
    <span>Explorar</span>
  </div>
</section>

<style>
  .hero {
    min-height: 100svh;
    padding-top: calc(var(--nav-height) + 5rem + 2rem);
    padding-bottom: 6rem;
    background: var(--color5);
    position: relative;
    overflow: hidden;
  }

  .hero__bg-pattern {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 70% 20%, var(--color4) 0%, transparent 60%),
      radial-gradient(ellipse 50% 40% at 20% 80%, var(--color3) 0%, transparent 50%);
    z-index: 0;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 6vw, 6rem);
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .hero__label {
    opacity: 0;
    animation: fadeUp 0.6s 0.1s ease forwards;
  }

  .hero__title {
    font-family: var(--font-heading);
    font-size: clamp(2.75rem, 5.5vw, 5rem);
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    opacity: 0;
    animation: fadeUp 0.7s 0.2s ease forwards;
  }

  .hero__title-accent {
    color: transparent;
    -webkit-text-stroke: 2px var(--color1);
    background: linear-gradient(135deg, #ff7aa3, var(--color1));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    -webkit-text-stroke: 0;
  }

  .hero__desc {
    font-size: clamp(1rem, 1.2vw, 1.125rem);
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 46ch;
    opacity: 0;
    animation: fadeUp 0.7s 0.3s ease forwards;
  }

  .hero__stats {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    opacity: 0;
    animation: fadeUp 0.7s 0.4s ease forwards;
  }

  .hero__stat {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .hero__stat-num {
    font-family: var(--font-heading);
    font-size: 1.875rem;
    font-weight: 800;
    color: var(--text-primary);
    line-height: 1;
  }

  .hero__stat-label {
    font-size: 0.75rem;
    color: var(--text-muted);
    line-height: 1.3;
    max-width: 10ch;
  }

  .hero__stat-divider {
    width: 1px;
    height: 36px;
    background: var(--color2);
    flex-shrink: 0;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    opacity: 0;
    animation: fadeUp 0.7s 0.5s ease forwards;
  }

  .hero__awards {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    opacity: 0;
    animation: fadeUp 0.7s 0.6s ease forwards;
  }

  .hero__award-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-secondary);
    background: var(--color4);
    border: 1px solid var(--color3);
    padding: 0.35rem 0.75rem;
    border-radius: 100px;
    white-space: nowrap;
  }

  .hero__award-badge svg {
    color: var(--color1);
    flex-shrink: 0;
  }

  /* Visual side */
  .hero__visual {
    position: relative;
    display: flex;
    justify-content: center;
    opacity: 0;
    animation: fadeIn 0.9s 0.3s ease forwards;
  }

  .hero__img-wrapper {
    position: relative;
    width: 100%;
    max-width: 420px;
  }

  .hero__img {
    width: 100%;
    height: auto;
    object-fit: cover;
    filter: drop-shadow(0 20px 48px rgba(255, 100, 150, 0.25));
    transition: filter var(--transition-slow);
  }

  .hero__img-wrapper:hover .hero__img {
    filter: drop-shadow(0 24px 56px rgba(255, 100, 150, 0.35));
  }

  .hero__img-card {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 0.625rem;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(12px);
    border: 1px solid var(--color3);
    border-radius: var(--radius-md);
    padding: 0.75rem 1rem;
    box-shadow: var(--shadow-md);
    animation: floatCard 4s ease-in-out infinite;
  }

  .hero__img-card svg {
    color: var(--color1);
    flex-shrink: 0;
  }

  .hero__img-card--top {
    top: 12%;
    right: -8%;
    animation-delay: 0s;
  }

  .hero__img-card--bottom {
    bottom: 15%;
    left: -8%;
    animation-delay: 2s;
  }

  .card-title {
    display: block;
    font-family: var(--font-heading);
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.2;
  }

  .card-sub {
    display: block;
    font-size: 0.7rem;
    color: var(--text-muted);
    line-height: 1.2;
  }

  .hero__floating-imgs {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero__float {
    position: absolute;
    border-radius: var(--radius-md);
    object-fit: cover;
    box-shadow: var(--shadow-lg);
    border: 3px solid var(--color5);
  }

  .hero__float--1 {
    top: -5%;
    left: -12%;
    width: 110px;
    height: 80px;
    transform: rotate(-6deg);
    animation: floatImg 5s 1s ease-in-out infinite;
  }

  .hero__float--2 {
    bottom: 8%;
    right: -10%;
    width: 90px;
    height: 115px;
    transform: rotate(5deg);
    animation: floatImg 5.5s 0.5s ease-in-out infinite;
  }

  .hero__scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    z-index: 1;
    animation: fadeIn 1s 1s ease both;
  }

  .hero__scroll-line {
    width: 1px;
    height: 48px;
    background: linear-gradient(to bottom, var(--color1), transparent);
    animation: scrollLine 1.8s ease-in-out infinite;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes floatCard {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-8px); }
  }

  @keyframes floatImg {
    0%, 100% { transform: rotate(-6deg) translateY(0); }
    50% { transform: rotate(-6deg) translateY(-10px); }
  }

  @keyframes scrollLine {
    0% { transform: scaleY(0); transform-origin: top; }
    50% { transform: scaleY(1); transform-origin: top; }
    51% { transform: scaleY(1); transform-origin: bottom; }
    100% { transform: scaleY(0); transform-origin: bottom; }
  }

  @media (max-width: 900px) {
    .hero__inner {
      grid-template-columns: 1fr;
    }

    .hero__visual {
      order: -1;
      max-width: 340px;
      margin: 0 auto;
    }

    .hero__img-card--top { right: -4%; }
    .hero__img-card--bottom { left: -4%; }
    .hero__float--1, .hero__float--2 { display: none; }

    .hero__title {
      font-size: clamp(2.25rem, 8vw, 3.5rem);
    }
  }

  @media (max-width: 480px) {
    .hero {
      padding-top: calc(var(--nav-height) + 3rem + 2rem);
    }

    .hero__stats {
      gap: 1rem;
    }

    .hero__stat-num {
      font-size: 1.5rem;
    }
  }
</style>
