---
import { Image } from 'astro:assets';
import imgEosR5 from '../assets/images/camaras/eos-r5-c.png';
import imgNikonZ7 from '../assets/images/camaras/nikon-Z-7II.png';

const cameras = [
  {
    name: 'Canon EOS R5',
    subtitle: 'Mirrorless Full Frame · Fotografía y Video 8K',
    image: imgEosR5,
    highlight: 'Cámara principal',
    specs: [
      { label: 'Sensor', value: 'CMOS Full Frame 45 MP' },
      { label: 'Procesador', value: 'DIGIC X' },
      { label: 'Video', value: '8K RAW 30p / 4K 120p a 10 bits' },
      { label: 'Velocidad', value: 'Hasta 20 fps (electrónico)' },
      { label: 'ISO', value: '100 – 51.200 (amp. 102.400)' },
      { label: 'Estabilización', value: '5 ejes · hasta 8 pasos EV' },
      { label: 'Enfoque', value: 'Dual Pixel AF II · 1053 puntos' },
      { label: 'Almacenamiento', value: 'CFexpress + SD UHS-II' },
    ],
    useCase: 'Documentales, retrato, naturaleza, alta resolución para impresión de gran formato.',
  },
  {
    name: 'Nikon Z7 II',
    subtitle: 'Mirrorless Full Frame · Resolución extrema',
    image: imgNikonZ7,
    highlight: 'Segunda cámara',
    specs: [
      { label: 'Sensor', value: 'CMOS BSI Full Frame 45.7 MP' },
      { label: 'Procesador', value: 'Doble EXPEED 6' },
      { label: 'Video', value: 'UHD 4K 60p · N-Log · HDMI 10bit' },
      { label: 'Velocidad', value: 'Hasta 10 fps (50 RAW burst)' },
      { label: 'ISO', value: '64 – 25.600 (amp. 32 – 102.400)' },
      { label: 'Estabilización', value: 'VR en el cuerpo' },
      { label: 'Enfoque', value: '493 puntos AF · cara y ojos' },
      { label: 'Almacenamiento', value: 'CFexpress/XQD + SD UHS-II' },
    ],
    useCase: 'Paisajes, arquitectura, vida silvestre, condiciones de baja luz.',
  },
];
---

<section class="cameras" id="equipo" aria-labelledby="cameras-heading">
  <div class="container">
    <header class="cameras__header">
      <p class="section-label">Mi equipo</p>
      <h2 class="cameras__title" id="cameras-heading">
        Herramientas de precisión para la imagen perfecta
      </h2>
      <p class="cameras__desc">
        Trabajo con sistema mirrorless full frame y lentes de gran apertura para maximizar
        el detalle en entornos de baja luz, complementado con técnica de larga exposición
        y fotografía aérea con dron.
      </p>
    </header>

    <div class="cameras__grid">
      {cameras.map(camera => (
        <article class="cameras__card" aria-label={`Especificaciones de ${camera.name}`}>
          <div class="cameras__card-badge">{camera.highlight}</div>

          <div class="cameras__img-wrap">
            <Image
              src={camera.image}
              alt={`${camera.name} - cámara fotográfica profesional`}
              width={360}
              format="webp"
              quality={85}
              loading="lazy"
              class="blur-img"
            />
          </div>

          <div class="cameras__card-body">
            <h3 class="cameras__card-name">{camera.name}</h3>
            <p class="cameras__card-sub">{camera.subtitle}</p>

            <dl class="cameras__specs">
              {camera.specs.map(spec => (
                <>
                  <dt>{spec.label}</dt>
                  <dd>{spec.value}</dd>
                </>
              ))}
            </dl>

            <div class="cameras__usecase">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/>
                <circle cx="12" cy="13" r="4"/>
              </svg>
              <span>{camera.useCase}</span>
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="cameras__workflow">
      <h3 class="cameras__workflow-title">Flujo de edición</h3>
      <div class="cameras__workflow-steps">
        {['Captura RAW', 'Selección', 'Edición no destructiva', 'Lightroom / Capture One', 'Exportación optimizada'].map((step, i) => (
          <div class="cameras__workflow-step">
            <span class="cameras__workflow-num" aria-hidden="true">{i + 1}</span>
            <span>{step}</span>
            {i < 4 && <span class="cameras__workflow-arrow" aria-hidden="true">→</span>}
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .cameras {
    padding: clamp(4rem, 8vw, 8rem) 0;
    background: var(--color5);
  }

  .cameras__header {
    max-width: 700px;
    margin-bottom: 3rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .cameras__title {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    line-height: 1.15;
  }

  .cameras__desc {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 60ch;
  }

  .cameras__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    margin-bottom: 3rem;
  }

  .cameras__card {
    background: var(--color4);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color3);
    overflow: hidden;
    position: relative;
    transition: all var(--transition-normal);
  }

  .cameras__card:hover {
    box-shadow: var(--shadow-xl);
    transform: translateY(-4px);
    border-color: var(--color2);
  }

  .cameras__card-badge {
    position: absolute;
    top: 1rem;
    right: 1rem;
    font-family: var(--font-heading);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: var(--color1);
    color: var(--text-primary);
    padding: 0.3rem 0.75rem;
    border-radius: 100px;
    z-index: 1;
  }

  .cameras__img-wrap {
    background: var(--color3);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2.5rem 2rem;
    min-height: 220px;
  }

  .cameras__img-wrap img {
    max-height: 180px;
    width: auto;
    object-fit: contain;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    filter: drop-shadow(0 8px 24px rgba(180, 60, 100, 0.2));
  }

  .cameras__card:hover .cameras__img-wrap img {
    transform: scale(1.06) translateY(-4px);
  }

  .cameras__card-body {
    padding: 1.75rem;
  }

  .cameras__card-name {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
    letter-spacing: -0.02em;
  }

  .cameras__card-sub {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
    line-height: 1.4;
  }

  .cameras__specs {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.5rem 1rem;
    margin-bottom: 1.5rem;
  }

  .cameras__specs dt {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    white-space: nowrap;
    align-self: center;
  }

  .cameras__specs dd {
    font-size: 0.88rem;
    color: var(--text-secondary);
    align-self: center;
    line-height: 1.35;
  }

  .cameras__usecase {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    background: var(--color3);
    border-radius: var(--radius-sm);
    padding: 0.875rem 1rem;
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.5;
    border-left: 3px solid var(--color1);
  }

  .cameras__usecase svg {
    color: var(--color1);
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  /* Workflow */
  .cameras__workflow {
    background: var(--color4);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color3);
    padding: 2rem;
  }

  .cameras__workflow-title {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 1.25rem;
  }

  .cameras__workflow-steps {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .cameras__workflow-step {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.88rem;
    color: var(--text-secondary);
  }

  .cameras__workflow-num {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    background: var(--color1);
    color: var(--text-primary);
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 700;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .cameras__workflow-arrow {
    color: var(--color2);
    font-weight: 700;
    margin-left: 0.25rem;
  }

  @media (max-width: 768px) {
    .cameras__grid {
      grid-template-columns: 1fr;
    }

    .cameras__workflow-steps {
      flex-direction: column;
      align-items: flex-start;
    }

    .cameras__workflow-arrow {
      display: none;
    }
  }
</style>
