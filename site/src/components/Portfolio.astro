---
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import PortfolioGallery from './islands/PortfolioGallery.tsx';
import type { GalleryPhoto } from './islands/PortfolioGallery.tsx';

const categories = [
  { id: 'all', label: 'Todo' },
  { id: 'naturaleza', label: 'Naturaleza' },
  { id: 'retratos', label: 'Retratos' },
  { id: 'paisajes', label: 'Paisajes' },
  { id: 'moda', label: 'Moda' },
  { id: 'maternidad', label: 'Maternidad' },
  { id: 'arquitectura', label: 'Arquitectura' },
  { id: 'deportiva', label: 'Deportiva' },
  { id: 'eventos', label: 'Eventos' },
  { id: 'nocturna', label: 'Nocturna' },
  { id: 'alimentos', label: 'Alimentos' },
  { id: 'de-calle', label: 'Calle' },
  { id: 'interiores', label: 'Interiores' },
  { id: 'colores', label: 'Mezcla de color' },
  { id: 'naturaleza-muerta', label: 'Naturaleza muerta' },
];

const allImgs = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/images/fotografias/**/*.{jpg,jpeg,png}',
  { eager: true }
);

function findImg(slug: string): ImageMetadata | undefined {
  const key = Object.keys(allImgs).find(k => k.endsWith(slug));
  return key ? allImgs[key].default : undefined;
}

type PhotoSize = 'normal' | 'tall' | 'wide' | 'large';
interface PhotoDef { slug: string; alt: string; category: string; size: PhotoSize; }

const photoDefs: PhotoDef[] = [
  ...Array.from({length: 14}, (_, i): PhotoDef => ({
    slug: `naturaleza/naturaleza_${i + 1}.jpg`,
    alt: `Fotografía documental de naturaleza y territorio en Colombia ${i + 1}`,
    category: 'naturaleza',
    size: i === 0 ? 'large' : i % 5 === 0 ? 'tall' : 'normal',
  })),
  ...Array.from({length: 8}, (_, i): PhotoDef => ({
    slug: `naturaleza/territorio_${i + 1}.jpg`,
    alt: `Fotografía documental de territorio colombiano ${i + 1}`,
    category: 'naturaleza',
    size: i % 4 === 1 ? 'wide' : 'normal',
  })),
  ...Array.from({length: 5}, (_, i): PhotoDef => ({
    slug: `retratos/retrato_${i + 1}.jpg`,
    alt: `Retrato fotográfico ${i + 1}`,
    category: 'retratos',
    size: i === 0 ? 'large' : i % 3 === 0 ? 'tall' : 'normal',
  })),
  ...Array.from({length: 5}, (_, i): PhotoDef => ({
    slug: `paisajes/paisaje_${i + 1}.jpg`,
    alt: `Fotografía de paisaje ${i + 1}`,
    category: 'paisajes',
    size: i === 0 ? 'wide' : 'normal',
  })),
  ...Array.from({length: 5}, (_, i): PhotoDef => ({
    slug: `moda/moda_${i + 1}.jpg`,
    alt: `Fotografía de moda ${i + 1}`,
    category: 'moda',
    size: i === 0 ? 'tall' : 'normal',
  })),
  ...Array.from({length: 5}, (_, i): PhotoDef => ({
    slug: `maternidad/maternidad_${i + 1}.jpg`,
    alt: `Fotografía de maternidad ${i + 1}`,
    category: 'maternidad',
    size: i % 3 === 1 ? 'tall' : 'normal',
  })),
  ...Array.from({length: 5}, (_, i): PhotoDef => ({
    slug: `arquitectura/arquitectura_${i + 1}.jpg`,
    alt: `Fotografía de arquitectura ${i + 1}`,
    category: 'arquitectura',
    size: i === 0 ? 'wide' : 'normal',
  })),
  ...Array.from({length: 5}, (_, i): PhotoDef => ({
    slug: `deportiva/deporte_${i + 1}.jpg`,
    alt: `Fotografía deportiva ${i + 1}`,
    category: 'deportiva',
    size: 'normal',
  })),
  ...Array.from({length: 5}, (_, i): PhotoDef => ({
    slug: `eventos/evento_${i + 1}.jpg`,
    alt: `Fotografía de eventos ${i + 1}`,
    category: 'eventos',
    size: i === 0 ? 'wide' : 'normal',
  })),
  ...Array.from({length: 5}, (_, i): PhotoDef => ({
    slug: `nocturna/nocturna_${i + 1}.jpg`,
    alt: `Fotografía nocturna de larga exposición ${i + 1}`,
    category: 'nocturna',
    size: i % 2 === 0 ? 'wide' : 'normal',
  })),
  ...Array.from({length: 5}, (_, i): PhotoDef => ({
    slug: `alimentos/alimentos_${i + 1}.jpg`,
    alt: `Fotografía de alimentos ${i + 1}`,
    category: 'alimentos',
    size: 'normal',
  })),
  ...Array.from({length: 5}, (_, i): PhotoDef => ({
    slug: `de-calle/de_calle_${i + 1}.jpg`,
    alt: `Fotografía de calle ${i + 1}`,
    category: 'de-calle',
    size: i % 3 === 0 ? 'tall' : 'normal',
  })),
  ...Array.from({length: 5}, (_, i): PhotoDef => ({
    slug: `interiores/interiores_${i + 1}.jpg`,
    alt: `Fotografía de interiores ${i + 1}`,
    category: 'interiores',
    size: i === 0 ? 'wide' : 'normal',
  })),
  ...Array.from({length: 5}, (_, i): PhotoDef => ({
    slug: `colores/colores_${i + 1}.jpg`,
    alt: `Fotografía mezcla de color ${i + 1}`,
    category: 'colores',
    size: 'normal',
  })),
  ...Array.from({length: 5}, (_, i): PhotoDef => ({
    slug: `naturaleza-muerta/naturaleza_muerta_${i + 1}.jpg`,
    alt: `Fotografía de naturaleza muerta ${i + 1}`,
    category: 'naturaleza-muerta',
    size: 'normal',
  })),
];

// Pre-optimiza todas las imágenes en build-time con getImage().
// Las URLs resueltas se pasan como JSON a la isla — cero re-procesamiento en cliente.
const galleryPhotos: GalleryPhoto[] = (
  await Promise.all(
    photoDefs.map(async (def): Promise<GalleryPhoto | null> => {
      const imgMeta = findImg(def.slug);
      if (!imgMeta) return null;
      const opt = await getImage({ src: imgMeta, width: 900, format: 'avif', quality: 75 });
      return { src: opt.src, alt: def.alt, category: def.category, size: def.size };
    })
  )
).filter((p): p is GalleryPhoto => p !== null);
---

<section class="portfolio" id="portafolio" aria-labelledby="portfolio-heading">
  <div class="container">
    <!-- Cabecera estática: SSR puro, cero JS -->
    <header class="portfolio__header">
      <p class="section-label">Portafolio</p>
      <h2 class="portfolio__title" id="portfolio-heading">Cada imagen, un argumento</h2>
      <p class="portfolio__desc">
        Más de 14 categorías fotográficas que documentan la riqueza natural, humana y cultural de Colombia.
      </p>
    </header>

    <!--
      Isla: filtros + galería + load-more + lightbox.
      client:visible → el bundle JS solo se carga cuando la sección entra al viewport.
      Las URLs de imagen ya vienen optimizadas del build (getImage), no hay trabajo en cliente.
    -->
    <PortfolioGallery
      photos={galleryPhotos}
      categories={categories}
      client:visible
    />
  </div>
</section>

<style>
  /* ── Sección y cabecera: elementos estáticos (scoped) ──────────────────── */

  .portfolio {
    padding: clamp(4rem, 8vw, 8rem) 0;
    background: var(--color3);
  }

  .portfolio__header {
    text-align: center;
    margin-bottom: 3rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .portfolio__header .section-label {
    justify-content: center;
  }

  .portfolio__title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    line-height: 1.1;
  }

  .portfolio__desc {
    color: var(--text-secondary);
    font-size: 1.05rem;
    max-width: 52ch;
    text-align: center;
    line-height: 1.7;
  }

  /* ── Elementos renderizados por la isla (necesitan ser globales) ────────── */

  :global(.portfolio__filters) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
    margin-bottom: 2.5rem;
  }

  :global(.portfolio__filter) {
    font-family: var(--font-heading);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-secondary);
    background: var(--color5);
    border: 1.5px solid var(--color2);
    padding: 0.5rem 1.125rem;
    border-radius: 100px;
    cursor: pointer;
    transition: all var(--transition-normal);
    white-space: nowrap;
  }

  :global(.portfolio__filter:hover),
  :global(.portfolio__filter.active) {
    background: var(--color1);
    border-color: var(--color1);
    color: var(--text-primary);
    box-shadow: var(--shadow-sm);
    transform: translateY(-1px);
  }

  :global(.portfolio__grid) {
    columns: 4 260px;
    gap: 1rem;
  }

  :global(.portfolio__item) {
    break-inside: avoid;
    margin-bottom: 1rem;
    border-radius: var(--radius-md);
    overflow: hidden;
    cursor: pointer;
    animation: portfolioItemIn 0.45s ease both;
  }

  @keyframes portfolioItemIn {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    :global(.portfolio__item) { animation: none; }
  }

  :global(.portfolio__item-inner) {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-md);
    background: var(--color4);
  }

  :global(.portfolio__item-inner img) {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    object-fit: cover;
    will-change: transform;
  }

  :global(.portfolio__item--tall .portfolio__item-inner img) {
    aspect-ratio: 3/4;
    object-fit: cover;
    width: 100%;
  }

  :global(.portfolio__item--wide .portfolio__item-inner img) {
    aspect-ratio: 16/9;
    object-fit: cover;
    width: 100%;
  }

  :global(.portfolio__item--large .portfolio__item-inner img) {
    aspect-ratio: 4/3;
    object-fit: cover;
    width: 100%;
  }

  :global(.portfolio__item:hover .portfolio__item-inner img) {
    transform: scale(1.06);
  }

  :global(.portfolio__overlay) {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(255, 100, 140, 0.5), transparent 50%);
    opacity: 0;
    transition: opacity var(--transition-normal);
    display: flex;
    align-items: flex-end;
    justify-content: flex-end;
    padding: 1rem;
  }

  :global(.portfolio__item:hover .portfolio__overlay) {
    opacity: 1;
  }

  :global(.portfolio__zoom) {
    background: rgba(255, 255, 255, 0.9);
    border-radius: 50%;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all var(--transition-fast);
    color: var(--text-primary);
    border: none;
  }

  :global(.portfolio__zoom:hover) {
    background: var(--color5);
    transform: scale(1.1);
  }

  :global(.portfolio__more) {
    display: flex;
    justify-content: center;
    margin-top: 3rem;
  }

  :global(.portfolio__load-more) {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-family: var(--font-heading);
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--text-primary);
    background: var(--color5);
    border: 2px solid var(--color1);
    padding: 0.875rem 1.75rem;
    border-radius: 100px;
    cursor: pointer;
    transition: all var(--transition-normal);
    white-space: nowrap;
  }

  :global(.portfolio__load-more:hover) {
    background: var(--color1);
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }

  :global(.portfolio__load-more svg) {
    transition: transform var(--transition-normal);
    flex-shrink: 0;
    color: var(--color1);
  }

  :global(.portfolio__load-more:hover svg) {
    transform: translateY(3px);
    color: var(--text-primary);
  }

  :global(.portfolio__load-more-badge) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 26px;
    height: 26px;
    padding: 0 0.375rem;
    background: var(--color1);
    color: var(--text-primary);
    border-radius: 100px;
    font-size: 0.72rem;
    font-weight: 800;
    line-height: 1;
    transition: background var(--transition-normal);
  }

  :global(.portfolio__load-more:hover .portfolio__load-more-badge) {
    background: rgba(255, 255, 255, 0.35);
  }

  /* Lightbox */
  :global(.lightbox) {
    position: fixed;
    inset: 0;
    z-index: 100;
    background: rgba(10, 0, 5, 0.92);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--transition-normal);
    backdrop-filter: blur(8px);
  }

  :global(.lightbox.open) {
    opacity: 1;
    pointer-events: auto;
  }

  :global(.lightbox__content) {
    max-width: 90vw;
    max-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  :global(.lightbox__content img) {
    max-width: 90vw;
    max-height: 90vh;
    object-fit: contain;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-xl);
  }

  :global(.lightbox__close),
  :global(.lightbox__prev),
  :global(.lightbox__next) {
    position: absolute;
    background: rgba(255, 255, 255, 0.15);
    border-radius: 50%;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    cursor: pointer;
    transition: all var(--transition-fast);
    backdrop-filter: blur(4px);
    border: none;
  }

  :global(.lightbox__close:hover),
  :global(.lightbox__prev:hover),
  :global(.lightbox__next:hover) {
    background: rgba(255, 255, 255, 0.25);
    transform: scale(1.1);
  }

  :global(.lightbox__close) { top: 1.5rem; right: 1.5rem; }
  :global(.lightbox__prev)  { left: 1.5rem; top: 50%; transform: translateY(-50%); }
  :global(.lightbox__next)  { right: 1.5rem; top: 50%; transform: translateY(-50%); }
  :global(.lightbox__prev:hover) { transform: translateY(-50%) scale(1.1); }
  :global(.lightbox__next:hover) { transform: translateY(-50%) scale(1.1); }

  @media (max-width: 768px) {
    :global(.portfolio__grid) {
      columns: 2 140px;
      gap: 0.75rem;
    }

    :global(.portfolio__item) {
      margin-bottom: 0.75rem;
    }

    :global(.lightbox__prev) { left: 0.75rem; }
    :global(.lightbox__next) { right: 0.75rem; }
  }

  /* Skeleton */
  :global(.portfolio__skeleton) {
    position: absolute;
    inset: 0;
    background: var(--color4);
    border-radius: var(--radius-sm);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 1;
  }

  :global(.portfolio__skeleton-shine) {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.55) 50%,
      transparent 100%
    );
    animation: skeleton-shine 1.6s ease-in-out infinite;
  }

  @keyframes skeleton-shine {
    from { transform: translateX(-100%); }
    to   { transform: translateX(100%); }
  }

  :global(.portfolio__skeleton-icon) {
    color: var(--color2);
    opacity: 0.7;
    z-index: 1;
  }

</style>
