---
import { Image } from 'astro:assets';
import logoImg from '../assets/images/logo.png';
import NavToggle from './islands/NavToggle.tsx';

const navLinks = [
  { href: '#portafolio', label: 'Portafolio' },
  { href: '#sobre-mi', label: 'Sobre mí' },
  { href: '#reconocimientos', label: 'Reconocimientos' },
  { href: '#equipo', label: 'Equipo' },
  { href: '#contacto', label: 'Contacto' },
];
---

<header class="navbar" id="navbar" role="banner">
  <nav class="navbar__inner container" aria-label="Navegación principal">
    <a href="/" class="navbar__logo" aria-label="Valentina Ríos Fotografía - Inicio">
      <Image src={logoImg} alt="Valentina Ríos Fotografía" width={84} height={72} format="webp" quality={75} fetchpriority="high" loading="eager" />
      <span class="navbar__name">Valentina Ríos</span>
    </a>

    <!-- Desktop links: HTML estático, cero JS -->
    <ul class="navbar__links" role="list">
      {navLinks.map(link => (
        <li>
          <a href={link.href} class="navbar__link">{link.label}</a>
        </li>
      ))}
    </ul>

    <a href="#contacto" class="btn-primary navbar__cta">Trabajemos juntos</a>

    <!-- Isla: hamburger + menú móvil. client:load → hidrata al cargar la página -->
    <NavToggle links={navLinks} client:idle />
  </nav>
</header>

<style>
  /* ── Elementos estáticos (Astro renderiza) ─────────────────────────────── */
  .navbar {
    position: fixed;
    top: 1rem;
    left: 1rem;
    right: 1rem;
    z-index: 50;
    border-radius: var(--radius-xl);
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid var(--color3);
    box-shadow: var(--shadow-md);
    transition: background-color var(--transition-normal), box-shadow var(--transition-normal);
  }

  .navbar.scrolled {
    background: rgba(255, 255, 255, 0.95);
    box-shadow: var(--shadow-lg);
  }

  .navbar__inner {
    display: flex;
    align-items: center;
    gap: 2rem;
    height: var(--nav-height);
  }

  .navbar__logo {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    flex-shrink: 0;
    cursor: pointer;
  }

  .navbar__logo img {
    width: 42px;
    height: 36px;
    filter: drop-shadow(0 1px 4px rgba(0, 0, 0, 0.18));
  }

  .navbar__name {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1rem;
    color: var(--text-primary);
    white-space: nowrap;
  }

  .navbar__links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
    margin-left: auto;
  }

  .navbar__link {
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
    padding: 0.5rem 0.875rem;
    border-radius: 100px;
    transition: color var(--transition-fast), background-color var(--transition-fast);
    cursor: pointer;
    white-space: nowrap;
  }

  .navbar__link:hover {
    color: var(--text-primary);
    background: var(--color4);
  }

  .navbar__cta {
    font-size: 0.8rem;
    padding: 0.625rem 1.25rem;
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .navbar__links,
    .navbar__cta {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .navbar__name {
      display: none;
    }
  }

  /* ── Elementos de la isla NavToggle (necesitan ser globales) ───────────── */

  :global(.navbar__toggle-wrap) {
    display: none;
    margin-left: auto;
  }

  @media (max-width: 768px) {
    :global(.navbar__toggle-wrap) {
      display: block;
    }
  }

  :global(.navbar__toggle) {
    display: flex;
    flex-direction: column;
    gap: 5px;
    padding: 8px;
    background: transparent;
    border: none;
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: background var(--transition-fast);
  }

  :global(.navbar__toggle:hover) {
    background: var(--color4);
  }

  :global(.navbar__toggle-bar) {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--text-primary);
    border-radius: 2px;
    transition: transform var(--transition-normal), opacity var(--transition-normal);
  }

  :global(.navbar__toggle.open .navbar__toggle-bar:nth-child(1)) {
    transform: translateY(7px) rotate(45deg);
  }

  :global(.navbar__toggle.open .navbar__toggle-bar:nth-child(2)) {
    opacity: 0;
  }

  :global(.navbar__toggle.open .navbar__toggle-bar:nth-child(3)) {
    transform: translateY(-7px) rotate(-45deg);
  }

  :global(.navbar__mobile-panel) {
    position: fixed;
    top: calc(1rem + 64px + 0.5rem);
    left: 1rem;
    right: 1rem;
    z-index: 49;
    background: rgba(255, 255, 255, 0.97);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color3);
    padding: 1rem 1.5rem 1.5rem;
    box-shadow: var(--shadow-lg);
    animation: navPanelIn 0.2s ease both;
  }

  @keyframes navPanelIn {
    from { opacity: 0; transform: translateY(-8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  :global(.navbar__mobile-panel ul) {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  :global(.navbar__mobile-link) {
    display: block;
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-secondary);
    padding: 0.75rem 1rem;
    border-radius: var(--radius-sm);
    transition: color var(--transition-fast), background-color var(--transition-fast);
    cursor: pointer;
  }

  :global(.navbar__mobile-link:hover) {
    color: var(--text-primary);
    background: var(--color4);
  }

  :global(.navbar__mobile-cta) {
    display: flex;
    margin-top: 1rem;
    width: 100%;
    justify-content: center;
  }
</style>
